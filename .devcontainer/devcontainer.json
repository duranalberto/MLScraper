{
  "name": "MLScraper",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteEnv": {
    "EDITOR": "code --wait",
    "VISUAL": "code --wait"
  },
  "forwardPorts": [
    80
  ],
  "portsAttributes": {
    "80": {
      "label": "MLScraper FastAPI",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "git config --global core.editor 'code --wait' && git config --global --add safe.directory /workspaces/MLScraper && if [ -d .git ]; then pre-commit install; fi",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": false,
        "python.testing.unittestEnabled": true,
        "python.testing.unittestArgs": [
          "-v",
          "-s",
          ".",
          "-p",
          "test_*.py"
        ],
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.terminal.activateEnvironment": false,
        "ruff.nativeServer": "on",
        "ruff.lint.enable": true,
        "black-formatter.args": [
          "--line-length",
          "100"
        ],
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "files.eol": "\n",
        "editor.rulers": [
          100
        ],
        "editor.formatOnPaste": false,
        "editor.formatOnSave": true,
        "chat.disableAIFeatures": true,
        "github.copilot.enable": {
          "*": false,
          "markdown": false,
          "plaintext": false,
          "scminput": false
        },
        "github.copilot.editor.enableCodeActions": false,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.fontFamily": "'Fira Code', 'FiraCode Nerd Font', Consolas, 'Courier New', monospace",
        "editor.fontLigatures": true,
        "terminal.integrated.fontFamily": "'FiraCode Nerd Font'",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        },
        "yaml.validate": true,
        "yaml.schemas": {
          "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.{yml,yaml}"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "[toml]": {
          "editor.defaultFormatter": "tamasfe.even-better-toml"
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "openai.chatgpt",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "editorconfig.editorconfig",
        "GitHub.vscode-pull-request-github",
        "donjayamanne.githistory",
        "mhutchie.git-graph"
      ]
    }
  }
}
